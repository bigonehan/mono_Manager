tmux 실동작 검증을 한 번 수행해 pane 분할/target 지정/출력 전달/패턴 판정을 확인하겠습니다. 이 결과를 check-code 판단의 근거로 사용하겠습니다.
exec
/usr/sbin/bash -lc 'set -euo pipefail
SESSION="verify_draft_$$"
TARGET_PATTERN="TMUX_VERIFY_OK"
ERR_PATTERN="TMUX_VERIFY_ERR"
RETRIES=3
SLEEP_SEC=0.3

cleanup(){ tmux has-session -t "$SESSION" 2>/dev/null && tmux kill-session -t "$SESSION" >/dev/null 2>&1 || true; }
trap cleanup EXIT

# create isolated session
tmux new-session -d -s "$SESSION" -x 120 -y 30
before_count=$(tmux list-panes -t "$SESSION" | wc -l)
before_layout=$(tmux display-message -p -t "$SESSION" '"'#{window_layout}')
before_active="'$(tmux display-message -p -t "$SESSION" '"'#{pane_id}')

# split and capture new pane id
new_pane="'$(tmux split-window -t "$SESSION":0.0 -h -P -F '"'#{pane_id}')
after_count="'$(tmux list-panes -t "$SESSION" | wc -l)
after_layout=$(tmux display-message -p -t "$SESSION" '"'#{window_layout}')

# explicitly target pane
if tmux select-pane -t \""'$new_pane" 2>/dev/null; then
  target_status="ok"
else
  target_status="fail"
fi
active_after_select=$(tmux display-message -p -t "$SESSION" '"'#{pane_id}')

# dispatch command to target pane (stdout+stderr)
cmd=\"echo "'$TARGET_PATTERN; >&2 echo $ERR_PATTERN"
tmux send-keys -t "$new_pane" "$cmd" C-m

# retry capture
captured=""
for i in $(seq 1 "$RETRIES"); do
  captured=$(tmux capture-pane -t "$new_pane" -p -S -60)
  if printf '"'%s' \""'$captured" | rg -q "$TARGET_PATTERN" && printf '"'%s' \""'$captured" | rg -q "$ERR_PATTERN"; then
    break
  fi
  sleep "$SLEEP_SEC"
done

if [ "$after_count" -le "$before_count" ]; then
  cause="split_failed"
elif [ "$target_status" != "ok" ] || [ "$active_after_select" != "$new_pane" ]; then
  cause="target_pane_select_failed"
elif ! printf '"'%s' \""'$captured" | rg -q "$TARGET_PATTERN"; then
  cause="output_not_delivered"
else
  cause="success"
fi

printf '"'BEFORE_COUNT=%s\\nAFTER_COUNT=%s\\nBEFORE_LAYOUT=%s\\nAFTER_LAYOUT=%s\\nBEFORE_ACTIVE=%s\\nACTIVE_AFTER_SELECT=%s\\nTARGET_PANE=%s\\nTARGET_STATUS=%s\\nCAUSE=%s\\n' \\
  \""'$before_count" "$after_count" "$before_layout" "$after_layout" "$before_active" "$active_after_select" "$new_pane" "$target_status" "$cause"

if printf '"'%s' \""'$captured" | rg -q "$TARGET_PATTERN"; then echo '"'STDOUT_PATTERN=matched'; else echo 'STDOUT_PATTERN=missed'; fi
if printf '%s' \""'$captured" | rg -q "$ERR_PATTERN"; then echo '"'STDERR_PATTERN=matched'; else echo 'STDERR_PATTERN=missed'; fi
