+  tmux send-keys -t "$pane_id" "bash '$script_path' > '$pane_log' 2>&1; code=\$?; printf '%s' \"\$code\" > '$pane_status'; tmux wait-for -S '$done_channel'" C-m
+  tmux wait-for "$done_channel"
+
