#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$ROOT_DIR"
LOG_DIR="$LOG_DIR"
STATUS_FILE="$STATUS_FILE"
TRANSITION_LOG="$TRANSITION_LOG"
FAILURE_LOG="$FAILURE_LOG"
CHANNEL_PREPARED="$CHANNEL_PREPARED"
CHANNEL_EXECUTED="$CHANNEL_EXECUTED"
CHANNEL_FAILED="$CHANNEL_FAILED"

on_exit() {
  local rc=
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '"'execute failed (exit=%s)\\n' \""'$rc" > "$FAILURE_LOG"
    printf '"'실패:execute\\n' >> \""'$TRANSITION_LOG"
    printf '"'실패\\n' > \""'$STATUS_FILE"
    tmux wait-for -S "$CHANNEL_FAILED"
  fi
}
trap on_exit EXIT

tmux wait-for "$CHANNEL_PREPARED"

{
  echo "panel=execute"
  echo "check=bash_syntax"
  bash -n "$ROOT_DIR/run_tmux_split_verification.sh"
  echo "check=asset_tokens"
  rg -q '"'<main class=\"landing\" id=\"programs\">' \""'$ROOT_DIR/index.html"
  rg -q '"'--accent:' \""'$ROOT_DIR/styles.css"
  rg -q '"'Programs: 3 pillars' \""'$ROOT_DIR/script.js"
  echo "result=ok"
} > "$LOG_DIR/pane_execute.log"

printf '"'실행\\n' > \""'$STATUS_FILE"
printf '"'실행\\n' >> \""'$TRANSITION_LOG"
tmux wait-for -S "$CHANNEL_EXECUTED"
EOF_EXEC

cat > "$RUNTIME_DIR/pane_finalize.sh" <<EOF_FINAL
#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$ROOT_DIR"
LOG_DIR="$LOG_DIR"
STATUS_FILE="$STATUS_FILE"
TRANSITION_LOG="$TRANSITION_LOG"
FAILURE_LOG="$FAILURE_LOG"
OUTPUT_DIR="$OUTPUT_DIR"
CHANNEL_EXECUTED="$CHANNEL_EXECUTED"
CHANNEL_COMPLETED="$CHANNEL_COMPLETED"
CHANNEL_FAILED="$CHANNEL_FAILED"

on_exit() {
  local rc=
  rc=$?
  if [[ $rc -ne 0 ]]; then
    printf '"'finalize failed (exit=%s)\\n' \""'$rc" > "$FAILURE_LOG"
    printf '"'실패:finalize\\n' >> \""'$TRANSITION_LOG"
    printf '"'실패\\n' > \""'$STATUS_FILE"
    tmux wait-for -S "$CHANNEL_FAILED"
  fi
}
trap on_exit EXIT

tmux wait-for "$CHANNEL_EXECUTED"

{
  echo "panel=finalize"
  echo "check=asset_existence"
  test -s "$ROOT_DIR/index.html"
  test -s "$ROOT_DIR/styles.css"
  test -s "$ROOT_DIR/script.js"
  echo "check=school_structure"
  rg -q '"'<header class=\"site-header\">' \""'$ROOT_DIR/index.html"
  rg -q '"'<section class=\"card\">' \""'$ROOT_DIR/index.html"
  rg -q '"'Dream Valley School' \""'$ROOT_DIR/index.html"
  echo "result=ok"
} > "$LOG_DIR/pane_finalize.log"

sha256sum "$ROOT_DIR/index.html" "$ROOT_DIR/styles.css" "$ROOT_DIR/script.js" | sed "s|$ROOT_DIR/||" > "$OUTPUT_DIR/assets.sha256"
cat "$OUTPUT_DIR/assets.sha256" > "$LOG_DIR/asset_hash.log"

printf '"'완료\\n' > \""'$STATUS_FILE"
printf '"'완료\\n' >> \""'$TRANSITION_LOG"
tmux wait-for -S "$CHANNEL_COMPLETED"
EOF_FINAL

chmod +x "$RUNTIME_DIR/pane_prepare.sh" "$RUNTIME_DIR/pane_execute.sh" "$RUNTIME_DIR/pane_finalize.sh"

printf '"'1:new-session\\n' >> \""'$ORDER_LOG"
tmux new-session -d -s "$SESSION_NAME" -n verify "bash '"'"'$RUNTIME_DIR/pane_prepare.sh'"'\"
tmux set-option -t \""'$SESSION_NAME" remain-on-exit on >/dev/null

printf '"'2:split execute pane\\n' >> \""'$ORDER_LOG"
tmux split-window -h -t "$SESSION_NAME:0" "bash '"'"'$RUNTIME_DIR/pane_execute.sh'"'\"

printf '3:split finalize pane\\n' >> \""'$ORDER_LOG"
tmux split-window -v -t "$SESSION_NAME:0.1" "bash '"'"'$RUNTIME_DIR/pane_finalize.sh'"'\"
tmux select-layout -t \""'$SESSION_NAME:0" tiled >/dev/null

final_state=""
for _ in $(seq 1 300); do
  final_state="$(cat "$STATUS_FILE")"
  if [[ "$final_state" == "완료" || "$final_state" == "실패" ]]; then
    break
  fi
  sleep 0.05
done

if [[ "$final_state" != "완료" && "$final_state" != "실패" ]]; then
  fail_now "timeout while waiting for tmux pane scripts"
fi

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  tmux list-panes -t "$SESSION_NAME:0" '"\\
    -F 'pane_index=#{pane_index} pane_id=#{pane_id} dead=#{pane_dead} dead_status=#{pane_dead_status}' \\
    | sort -n > \""'$LOG_DIR/pane_status.log"

  while read -r pane_index pane_id; do
    tmux capture-pane -p -t "$pane_id" > "$LOG_DIR/tmux_pane_${pane_index}.log"
  done < <(tmux list-panes -t "$SESSION_NAME:0" -F '"'#{pane_index} #{pane_id}' | sort -n)
fi

expected_transition="'$'"'초기\\n준비\\n실행\\n완료\\n'
if [[ \""'$final_state" == "완료" ]]; then
  if [[ "$(cat "$TRANSITION_LOG")"$'"'\\n' "'!= "$expected_transition" ]]; then
    fail_now "unexpected transition order"
  fi
  printf '"'4:result=success\\n' >> \""'$ORDER_LOG"
  printf '"'success\\n' > \""'$OUTPUT_DIR/result.txt"
else
  printf '"'4:result=failure\\n' >> \""'$ORDER_LOG"
  [[ -s "$FAILURE_LOG" ]] || printf '"'unknown failure\\n' > \""'$FAILURE_LOG"
  tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true
  exit 1
fi

tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true
EOF
