#"'!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="/home/tree/project/rust-orc/.tmp_tmux_test2"
ARTIFACT_DIR="$ROOT_DIR/.artifacts/workspace_bootstrap"
LOG_DIR="$ARTIFACT_DIR/logs"
STATE_DIR="$ARTIFACT_DIR/state"
RUNTIME_DIR="$ARTIFACT_DIR/runtime"
OUTPUT_DIR="$ARTIFACT_DIR/output"
STATUS_FILE="$STATE_DIR/status.txt"
TRANSITION_LOG="$LOG_DIR/transition.log"
FAILURE_LOG="$LOG_DIR/failure_reason.log"
ORDER_LOG="$LOG_DIR/command_order.log"

fail_now() {
  local reason="$1"
  printf '"'실패\\n' > \""'$STATUS_FILE"
  printf '"'실패:%s\\n' \""'$reason" >> "$TRANSITION_LOG"
  printf '"'%s\\n' \""'$reason" > "$FAILURE_LOG"
  exit 1
}

if [[ ! -d "$ROOT_DIR" ]]; then
  echo "workspace path is missing: $ROOT_DIR" >&2
  exit 1
fi

cd "$ROOT_DIR"

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required" >&2
  exit 1
fi

SESSION_SUFFIX="$(printf '"'%s' \""'$ROOT_DIR" | sha1sum | cut -c1-10)"
SESSION_NAME="workspace_bootstrap_${SESSION_SUFFIX}"
CHANNEL_PREPARED="${SESSION_NAME}_prepared"
CHANNEL_EXECUTED="${SESSION_NAME}_executed"
CHANNEL_COMPLETED="${SESSION_NAME}_completed"
CHANNEL_FAILED="${SESSION_NAME}_failed"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  tmux kill-session -t "$SESSION_NAME"
fi

rm -rf "$ARTIFACT_DIR"
mkdir -p "$LOG_DIR" "$STATE_DIR" "$RUNTIME_DIR" "$OUTPUT_DIR"

: > "$TRANSITION_LOG"
: > "$ORDER_LOG"
: > "$FAILURE_LOG"
printf '"'초기\\n' > \""'$STATUS_FILE"
printf '"'초기\\n' >> \""'$TRANSITION_LOG"

