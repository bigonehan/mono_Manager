#"'!/usr/bin/env bash
set -euo pipefail

session_name="tmux_split_verification_for_school_landing_page"

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required"
  exit 1
fi

tmux new-session -d -s "$session_name" "python3 -m http.server 8080"
tmux split-window -h -t "$session_name" "echo hello world; read -r"
tmux select-layout -t "$session_name" even-horizontal
tmux attach -t "$session_name"
EOF

