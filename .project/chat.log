FEATURE_NAME: llm_chat_system
```yaml
rule:
  - command == 'orc chat -n "{name}"'
  - chat_mode_enabled == true
  - file_exists('.temp/{name}.yaml') == true
  - missing('.temp/{name}.yaml') => error_and_exit
  - file_format('.temp/{name}.yaml') == 'yaml'
  - session_id = build_llm_id() and matches(session_id, '^[0-9]{8}$')
  - llm_id == session_id
  - message_schema == 'message_id|command|data|receiver|sender_id'
  - chat_exit_shortcut == 'ctrl+d'
  - startup_help_contains('ctrl+d') == true
features:
  domain:
    - chat
  flow:
    - activate_chat_mode
    - assign_llm_id
    - poll_messages_by_last_read_message_id
task:
  - name: activate_llm_chat_system
    type: action
    domain:
      - chat
    depends_on: []
    scope:
      - .temp/{name}.yaml
      - src/cli/chat.rs
      - src/chat/session.rs
    rule:
      - input.name != ''
      - file_exists('.temp/{name}.yaml') == true
      - missing('.temp/{name}.yaml') => error_and_exit
      - matches(session_id, '^[0-9]{8}$') == true
      - llm_id == session_id
      - users_contains_sender_id(session_id) == true
      - read_messages_by_last_read_message_id == true
      - wait_time == config.MAX_read_time
      - has_new_messages => print_and_update_last_read_message_id
    step:
      - input: command 'orc chat -n "a"' -> output: chat mode activation requested
      - input: '.temp/a.yaml' path -> output: file existence check result
      - input: missing '.temp/a.yaml' -> output: print error and exit
      - input: existing '.temp/a.yaml' -> output: call build_llm_id() to create 8-digit session_id
      - input: generated session_id -> output: set runtime variable llm_id
      - input: llm_id -> output: reflect sender_id(session_id) into users
      - input: '.temp/{name}.yaml' and last_read_message_id -> output: read messages
      - input: config.MAX_read_time -> output: wait
      - input: '.temp/{name}.yaml' and last_read_message_id -> output: re-read messages
      - input: new messages detected -> output: print messages and update last_read_message_id
    touches:
      - runtime.session_id
      - runtime.llm_id
      - .temp/{name}.yaml#users
      - .temp/{name}.yaml#messages
      - runtime.last_read_message_id
      - config.MAX_read_time
    contracts:
      - session_id=matches('^[0-9]{8}$')
      - llm_id_equals_session_id=true
      - chat_file_exists=file_exists('.temp/{name}.yaml') == true
      - chat_file_autocreate=false
      - message_fields=message_id|command|data|receiver|sender_id
      - exit_shortcut=ctrl+d
```


