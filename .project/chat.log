[1772521942] LLM_RESPONSE
FEATURE_NAME: llm_chat_system
```yaml
rule:
  - command_matches("orc chat -n <name>") == true
  - yaml_file_exists(".temp/<name>.yaml") == true
  - yaml_format(".temp/<name>.yaml") == true
features:
  domain:
    - chat
  flow:
    - start_chat_session
    - poll_chat_messages
task:
  - name: start_chat_session
    type: action
    domain:
      - chat
    depends_on: []
    scope:
      - src/cli/mod.rs
      - src/chat/mod.rs
      - src/chat/session.rs
      - src/chat/storage.rs
      - .temp/<name>.yaml
    rule:
      - file_exists(".temp/<name>.yaml") == true
      - build_llm_id() -> matches("^[A-Za-z0-9]{8}$")
      - llm_id == session_id
      - sender_id == session_id
      - help_contains("ctrl+d") == true
      - on_missing_file(error) == true
      - auto_create_file == false
    step:
      - input: `orc chat -n "<name>"` -> output: `chat mode started or error`
      - input: `.temp/<name>.yaml exists?` -> output: `false => print error and exit`
      - input: `.temp/<name>.yaml exists?` -> output: `true => call build_llm_id()`
      - input: `build_llm_id()` -> output: `8-char session_id and set llm_id`
      - input: `session_id` -> output: `users.sender_id updated`
      - input: `messages + last_read_message_id` -> output: `display unread messages`
      - input: `wait config.MAX_read_time` -> output: `reload messages from .temp/<name>.yaml`
      - input: `new messages detected` -> output: `display + update last_read_message_id`
    touches:
      - cli.chat
      - chat.session_id
      - chat.llm_id
      - chat.users.sender_id
      - chat.messages.polling
    contracts:
      - session_id: matches("^[A-Za-z0-9]{8}$")
      - llm_id: equals(session_id)
      - message_schema: "message_id|command|data|receiver|sender_id"
      - storage_file: ".temp/<name>.yaml"
      - poll_interval: "wait == config.MAX_read_time"
      - missing_file_behavior: "error_and_exit"
```


