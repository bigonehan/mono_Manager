      - "messages에 message_id=<new_id>, command=\"hello\", data=null, receiver=null, sender_id=<llm_id>를 추가 저장한다."
    touches:
      - ".temp/<name>.yaml#messages"
      - "runtime.llm_id"
    contracts:
      - "sender_id =~ '^[A-Za-z0-9]{8}$'"
      - "message_id =~ '^[A-Za-z0-9_-]+$'"
      - "command == input.message"
      - "receiver == null or receiver == input.receiver_id"
      - "data == null or data == input.data"
      - "append_only(messages) == true"
