[1772522892] LLM_RESPONSE
FEATURE_NAME: run_llm_chat_session
```yaml
rule:
  - command == "orc chat -n <name>"
  - chat_file_ext == ".yaml"
features:
  domain:
    - chat
  flow:
    - validate_room_file -> build_llm_id -> assign_sender -> read_messages -> wait_max_read_time -> read_new_messages
task:
  - name: run_llm_chat_session
    type: action
    domain:
      - chat
    depends_on: []
    scope:
      - .temp/<name>.yaml
      - src/cli/mod.rs
      - src/chat/mod.rs
    rule:
      - file_exists(".temp/<name>.yaml") == true
      - len(session_id) == 8
      - matches(session_id, "^[A-Za-z0-9]{8}$")
      - llm_id == session_id
      - users_contains(sender_id=session_id) == true
      - on_ctrl_d == "print_exit_help_and_exit"
    step:
      - input: run `orc chat -n "a"` -> output: chat mode start requested
      - input: check `.temp/a.yaml` exists -> output: if false print error and exit
      - input: call `build_llm_id()` -> output: create 8-char random `session_id`
      - input: assign `llm_id = session_id` -> output: llm_id stored
      - input: update users with `sender_id=session_id` -> output: sender registered
      - input: read `.temp/<name>.yaml` messages by `last_read_message_id` -> output: print unread messages
      - input: wait `MAX_read_time` -> output: poll interval elapsed
      - input: reread messages -> output: print new messages and update `last_read_message_id`
      - input: press `ctrl+d` -> output: print exit help and terminate chat mode
    touches:
      - .temp/<name>.yaml
      - llm_id
      - session_id
      - users.sender_id
      - last_read_message_id
    contracts:
      - room_file_required: file_exists(".temp/<name>.yaml") == true
      - room_file_format: ends_with("<name>.yaml", ".yaml") == true
      - session_id_contract: matches(session_id, "^[A-Za-z0-9]{8}$")
      - llm_id_contract: llm_id == session_id
      - message_schema: keys(message) == ["message_id","command","data","receiver","sender_id"]
      - read_cursor_contract: last_read_message_id increases_monotonic == true
      - exit_contract: on_ctrl_d == "print_exit_help_and_exit"
```


