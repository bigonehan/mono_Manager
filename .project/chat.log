[1772521744] LLM_RESPONSE
FEATURE_NAME: llm_chat_system
```yaml
rule:
  - command == "orc chat -n <name>"
  - file_exists(".temp/<name>.yaml") == true
  - chat_file_format == "yaml"
features:
  domain:
    - chat
  flow:
    - validate_room_file
    - assign_session_id
    - bind_sender
    - poll_new_messages
    - exit_on_ctrl_d
task:
  - name: "activate_chat_mode"
    type: "action"
    domain:
      - chat
    depends_on: []
    scope:
      - ".temp/<name>.yaml"
    rule:
      - file_exists(".temp/<name>.yaml") == true
      - file_auto_create(".temp/<name>.yaml") == false
      - llm_id == session_id
      - session_id.matches("^[0-9]{8}$") == true
      - chat_exit_key == "ctrl+d"
      - message_schema == "message_id|command|data|receiver|sender_id"
    step:
      - command("orc chat -n <name>") -> validate file(".temp/<name>.yaml") exists -> print error and exit when missing
      - file(".temp/<name>.yaml") + build_llm_id() -> generate session_id(8-digit random) -> set llm_id=session_id
      - llm_id + users -> update users.sender_id with session_id -> persist to file(".temp/<name>.yaml")
      - file(".temp/<name>.yaml") + last_read_message_id -> read messages -> display unread messages
      - wait(MAX_read_time) + file(".temp/<name>.yaml") -> reload messages -> display new messages and update last_read_message_id
      - chat_mode_start -> print help("종료: ctrl+d") -> exit on ctrl+d
    touches:
      - llm_id
      - session_id
      - users.sender_id
      - messages
      - last_read_message_id
      - MAX_read_time
    contracts:
      - session_id=matches("^[0-9]{8}$")
      - llm_id==session_id
      - users.sender_id contains session_id
      - message_id!=null
      - command!=null
      - data!=null
      - receiver!=null
      - sender_id!=null
      - file_auto_create==false
      - missing_file_exit_code!=0
```


